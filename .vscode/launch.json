      "program": "lib/main.dart",
      "deviceId": "linux",
      "flutterMode": "debug",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://localhost:8080"
      ],
      "templateFor": "frontend"
    }
  ]
